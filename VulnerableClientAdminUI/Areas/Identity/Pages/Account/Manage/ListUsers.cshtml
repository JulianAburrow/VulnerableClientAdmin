@page
@model ListUsersModel

@if (Model.Users == null)  
{
    return;
}
@{
    ViewData["Title"] = "List of all users";
}

@if (User.IsInRole(RoleNames.SuperUserOnly)) {

    <h1>@ViewData["Title"]</h1>

    <table class="table">
        <thead>
            <tr>
                <th>User name</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => user.UserName)
                </td>
                <td>
                    <a asp-page="./UserDetails" asp-route-id="@user.Id" class="btn btn-primary">User Details</a>
                    &nbsp;
                    <a asp-page="./AddUserToRole" asp-route-id="@user.Id" class="btn btn-primary">Add To Role</a>
                    &nbsp;
                    <a asp-page="./RemoveUserFromRole" asp-route-id="@user.Id" class="btn btn-danger">Remove From Role</a>
                    <span hidden="@(user.UserName == CommonValues.SystemLordUserName ||
                                    user.UserName == CommonValues.SuperUserRoleName ||
                                    user.UserName == CommonValues.UserRoleName)">
                        &nbsp;
                        <a asp-page="./DeleteUser" asp-route-id="@user.Id" class="btn btn-danger">Delete User</a>
                    </span>
                </td>
            </tr>
        }                
        </tbody>
    </table>
    @:&nbsp;
    <a href="~/" class="btn btn-primary">Home</a>
}
