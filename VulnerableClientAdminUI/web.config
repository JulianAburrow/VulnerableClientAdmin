<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
		<aspNetCore processPath="dotnet" arguments=".\VulnerableClientAdminUI.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess">
			<!--<environmentVariables>
				<environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Debug_T1" />
			</environmentVariables>-->
		</aspNetCore>
    </system.webServer>
  </location>
</configuration>