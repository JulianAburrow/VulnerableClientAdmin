<AuthorizeView>
    <Authorized>
        <div style="float: left; margin: 10px">
            Logged in as @context.User.Identity?.Name
        </div>
        <form method="post" action="Identity/Account/Logout">
            <button type="submit" class="btn btn-light">Log out</button>
        </form>
    </Authorized>
</AuthorizeView>