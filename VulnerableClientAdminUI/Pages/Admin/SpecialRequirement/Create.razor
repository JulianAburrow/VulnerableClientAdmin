@page "/specialrequirement/create"
@inherits SpecialRequirementBasePageClass

<PageTitle>Create Special Requirement</PageTitle>

<AuthorizeView Policy="AdminPolicy">
    <Authorized>

        <EditForm Context="subcontext" Model="@SpecialRequirementDisplayModel" OnValidSubmit="CreateSpecialRequirement">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <SpecialRequirementCreateUpdateComponent SpecialRequirementDisplayModel="@SpecialRequirementDisplayModel" />

        </EditForm>

    </Authorized>
</AuthorizeView>