@page "/specialrequirement/view/{SpecialRequirementId:int}"
@inherits SpecialRequirementBasePageClass

<PageTitle>View Special Requirement</PageTitle>

<AuthorizeView Policy="@PolicyNames.AdminRolePolicy">
    <Authorized>

        <br />

        @if (SpecialRequirementModel is null)
        {
            <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Loading Special Requirement</MudAlert>
            return;
        }

        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

            <MudTabPanel Text="Details">
                <MudGrid>
                    <MudItem sm="12">
                        <MudCard>
                            <SpecialRequirementDisplayComponent SpecialRequirementModel="@SpecialRequirementModel" />
                            <MudCardActions>
                                <a href="specialrequirement/edit/@SpecialRequirementModel.SpecialRequirementId" class="btn btn-primary">Edit</a>
                                @if (!PreventDeleting)
                                {
                                    @:&nbsp;
                                    <a href="specialrequirement/delete/@SpecialRequirementModel.SpecialRequirementId" class="btn btn-danger">Delete</a>
                                }
                                &nbsp;
                                <a class="btn btn-primary" href="specialrequirements/index">Back to list</a>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Audit">
                <AuditObjectsComponent AuditObjectList="@AuditObjects" />
            </MudTabPanel>
        </MudTabs>

        <CreatedLastUpdatedDisplayComponent CreatedBy="@SpecialRequirementModel.CreatedBy"
                                            DateCreated="@SpecialRequirementModel.DateCreated"
                                            LastUpdatedBy="@SpecialRequirementModel.LastUpdatedBy"
                                            DateLastUpdated="@SpecialRequirementModel.DateLastUpdated" />

    </Authorized>
    <NotAuthorized>

        <NotAuthorisedTextComponent />

    </NotAuthorized>
</AuthorizeView>