@page "/preferredcontactmethod/create"
@inherits PreferredContactMethodBasePageClass

<PageTitle>Create Preferred Contact Method</PageTitle>

<AuthorizeView Policy="@PolicyNames.AdminRolePolicy">
    <Authorized>

        <EditForm Context="subcontext" Model="@PreferredContactMethodDisplayModel" OnValidSubmit="CreatePreferredContactMethod">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <PreferredContactMethodCreateUpdateComponent PreferredContactMethodDisplayModel="@PreferredContactMethodDisplayModel" />

        </EditForm>

    </Authorized>
    <NotAuthorized>

        <NotAuthorisedTextComponent />

    </NotAuthorized>
</AuthorizeView>

