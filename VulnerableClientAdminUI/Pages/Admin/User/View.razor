@page "/user/view/{Id}"
@inherits UserBasePageClass

<PageTitle>View User</PageTitle>

<AuthorizeView Policy="AdminPolicy">
    <Authorized>

        <br />

        @if (User is null)
        {
            <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Loading User</MudAlert>
            return;
        }

        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

            <MudTabPanel Text="Details">
                <MudGrid>
                    <MudItem sm="12">
                        <MudCard>
                            <UserDisplayComponent User="@User" />
                            <MudCardActions>
                                <a href="user/edit/@User.Id" class="btn btn-primary">Edit</a>
                                @if (!PreventDeleting)
                                {
                                    @:&nbsp;
                                    <a href="user/delete/@User.Id" class="btn btn-danger">Delete</a>
                                }
                                &nbsp;
                                <a class="btn btn-primary" href="users/index">Back to list</a>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Audit">
                <AuditObjectsComponent AuditObjectList="@AuditObjects" />
            </MudTabPanel>
        </MudTabs>

    </Authorized>
</AuthorizeView>