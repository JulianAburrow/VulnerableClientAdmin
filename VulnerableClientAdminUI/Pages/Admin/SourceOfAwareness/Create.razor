@page "/sourceofawareness/create"
@inherits SourceOfAwarenessBasePageClass

<PageTitle>Create Source Of Awareness</PageTitle>

<AuthorizeView Policy="@PolicyNames.AdminRolePolicy">
    <Authorized>

        <EditForm Context="subcontext" Model="@SourceOfAwarenessDisplayModel" OnValidSubmit="CreateSourceOfAwareness">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <SourceOfAwarenessCreateUpdateComponent SourceOfAwarenessDisplayModel="@SourceOfAwarenessDisplayModel" />

        </EditForm>

    </Authorized>
</AuthorizeView>