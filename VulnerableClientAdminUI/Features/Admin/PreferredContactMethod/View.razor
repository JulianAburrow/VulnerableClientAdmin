@page "/preferredcontactmethod/view/{PreferredContactMethodId:int}"
@inherits PreferredContactMethodBasePageClass

<PageTitle>View Preferred Contact Method</PageTitle>

@* <AuthorizeView Roles="@RoleNames.SuperUserOnly">
    <Authorized> *@

        <br />

        @if (PreferredContactMethodModel == null)
        {
            <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Loading Preferred Contact Method</MudAlert>
            return;
        }

        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

            <MudTabPanel Text="Details">
                <MudGrid>
                    <MudItem sm="12">
                        <MudCard>
                            <PreferredContactMethodDisplayComponent PreferredContactMethodModel="@PreferredContactMethodModel" />
                            <MudCardActions>
                                <a href="preferredcontactmethod/edit/@PreferredContactMethodModel.PreferredContactMethodId" class="btn btn-primary">Edit</a>
                                @if (!PreventDeleting)
                                {
                                    @:&nbsp;
                                    <a href="preferredcontactmethod/delete/@PreferredContactMethodModel.PreferredContactMethodId" class="btn btn-danger">Delete</a>
                                }
                                &nbsp;
                                <a class="btn btn-primary" href="preferredcontactmethods/index">Back to list</a>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Audit">
                <AuditObjectsComponent AuditObjectList="@AuditObjects" />
            </MudTabPanel>
        </MudTabs>

        <CreatedLastUpdatedDisplayComponent CreatedBy="@PreferredContactMethodModel.CreatedBy"
                                            DateCreated="@PreferredContactMethodModel.DateCreated"
                                            LastUpdatedBy="@PreferredContactMethodModel.LastUpdatedBy"
                                            DateLastUpdated="@PreferredContactMethodModel.DateLastUpdated" />

