@page "/specialrequirements/index"
@inherits SpecialRequirementBasePageClass

<PageTitle>Special Requirements</PageTitle>

@* <AuthorizeView Roles="@RoleNames.SuperUserOnly">
    <Authorized> *@

        @if (SpecialRequirements == null)
        {
            <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Loading Special Requirements</MudAlert>
            return;
        }

        <br />

        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

            <MudTabPanel Text="Admin">

                <br />

                <a href="specialrequirement/create" class="btn btn-primary">Add new</a>

                <br />
                <br />

                <MudTable Items="SpecialRequirements"
                    Hover
                    FixedHeader="true"
                    Height="500">
                    <HeaderContent>
                        <MudTh title="Sort by Requirement">
                            <MudTableSortLabel SortBy="new Func<SpecialRequirementModel, object>(x => x.Requirement)">
                                Requirement
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh title="Sort by Active">
                            <MudTableSortLabel SortBy="new Func<SpecialRequirementModel, object>(x => x.RequirementActive)">
                                Active
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh title="Sort by Usage">
                            <MudTableSortLabel SortBy="new Func<SpecialRequirementModel, object>(x => x.Vulnerabilities.Count)">
                                Usage
                            </MudTableSortLabel>
                        </MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="subcontext">
                        <MudTd title="@subcontext.Description">@subcontext.Requirement</MudTd>
                        <MudTd>@subcontext.RequirementActive</MudTd>
                        <MudTd>@subcontext.Vulnerabilities.Count</MudTd>
                        <MudTd>
                            <a class="btn btn-primary" href="specialrequirement/view/@subcontext.SpecialRequirementId">View</a>
                            &nbsp;
                            <a class="btn btn-primary" href="specialrequirement/edit/@subcontext.SpecialRequirementId">Edit</a>
                            @if (!subcontext.Vulnerabilities.Any())
                            {
                                @:&nbsp;
                                <a class="btn btn-danger" href="specialrequirement/delete/@subcontext.SpecialRequirementId">Delete</a>
                            }
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100, int.MaxValue }" />
                    </PagerContent>
                </MudTable>

            </MudTabPanel>
            <MudTabPanel Text="Audit">

                <AuditObjectsComponent AuditObjectList="@AuditObjects" />

            </MudTabPanel>

        </MudTabs>

@*     </Authorized>
</AuthorizeView> *@