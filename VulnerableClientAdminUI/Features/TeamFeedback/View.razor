@page "/teamfeedback/view/{TeamFeedbackId:int}"
@inherits TeamFeedbackBasePageClass

<PageTitle>View Team Feedback</PageTitle>

@if (TeamFeedbackModel == null)
{
    <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Loading Team Feedback</MudAlert>
    return;
}

<br />

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

    <MudTabPanel Text="Details">
        <TeamFeedbackDisplayComponent TeamFeedbackModel="@TeamFeedbackModel" />
    </MudTabPanel>
    
@*     <AuthorizeView Roles="@RoleNames.SuperUserOnly">
        <Authorized> *@
            <MudTabPanel Text="Audit">
                <AuditObjectsComponent AuditObjectList="@AuditObjects" />
            </MudTabPanel>
@*         </Authorized>
    </AuthorizeView> *@

</MudTabs>

<CreatedLastUpdatedDisplayComponent
    CreatedBy="@TeamFeedbackModel.CreatedBy"
    DateCreated="@TeamFeedbackModel.DateCreated"
    LastUpdatedBy="@TeamFeedbackModel.LastUpdatedBy"
    DateLastUpdated="@TeamFeedbackModel.DateLastUpdated" />
